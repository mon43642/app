{
  "name": "repairdeck",
  "version": "1.0.0",
  "description": "RepairDeck - ADB phone repair console (Electron desktop app)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.repairdeck.app",
    "productName": "RepairDeck",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "platform-tools",
        "to": "platform-tools",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "directories": {
      "output": "dist"
    }
  }
}
